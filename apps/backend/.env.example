# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql://dev:dev@localhost:5432/bastion_nexus

# Security Keys (đổi thành chuỗi ngẫu nhiên mạnh khi deploy production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
ENCRYPTION_KEY=your-encryption-key-change-this-in-production

# HIBP API (tuỳ chọn — bỏ trống sẽ dùng chế độ giả lập)
HIBP_API_KEY=

# Redis — Local Docker
REDIS_URL=redis://localhost:6379

# Redis — Production (Upstash hoặc Redis Cloud)
# UPSTASH_REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# Socket.IO
SOCKET_CORS_ORIGIN=http://localhost:5173

# BullMQ Dashboard (truy cập tại /api/queues)
BULL_BOARD_ENABLED=false

# Prisma
RUN_MIGRATIONS=true

# SMTP (tuỳ chọn — cho gửi email)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=yourpassword
# SMTP_FROM=no-reply@example.com
